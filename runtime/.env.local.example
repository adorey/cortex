# cortex-runtime — local secrets template (ADR-002 §3.6)
# Copy to `.env.local` (gitignored, NEVER committed) and fill in for local development.
# In production these come from a K8s Secret / a vault via env, NOT from a file.
#
# Per-tenant scoping: prefix each key with the workspace name (uppercased), e.g. WBTB_*.
# Unprefixed keys work for a single-tenant local setup.

# --- single-tenant (no namespace) ---
LLM_KEY=sk-ant-xxxxxxxxxxxxxxxx
ISSUE_TRACKER_TOKEN=
CODE_HOST_TOKEN=
DB_CREDS=
WEBHOOK_HMAC=
RUNTIME_API_TOKEN=

# --- multi-tenant example (namespace = workspace) ---
# WBTB_LLM_KEY=sk-ant-...
# WBTB_ISSUE_TRACKER_TOKEN=...
# BLUSPARK_LLM_KEY=sk-ant-...
