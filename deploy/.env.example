# deploy/.env — copy to `.env` (gitignored). Secrets + the project to mount.

# Absolute path to the project the agent works on (mounted read-only at /workspace).
# It must contain its own cortex/ submodule (the spec) + a .mcp.json.
CORTEX_PROJECT_PATH=/path/to/your-project

CORTEX_WORKSPACE=acme
CORTEX_THEME=h2g2
CORTEX_BACKEND=claude-cli          # claude-cli | anthropic-api | demo

# Postgres (the state store) — used by both the runtime and the postgres service
POSTGRES_PASSWORD=cortex
# Host port to publish Postgres on (pick a free one to avoid clashing with other local Postgres).
# Your DB editor then connects to localhost:${POSTGRES_PORT}. The container port stays 5432.
POSTGRES_PORT=5432

# --- secrets ---
# claude-cli backend (Pro/Max subscription token from `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=

# cortex_jsm MCP (Jira read + internal comment, Basic auth)
JIRA_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_BEARER_TOKEN=
