{
  "openapi": "3.1.0",
  "info": {
    "title": "cortex-runtime",
    "version": "0.1.0",
    "description": "Agnostic engine API (ADR-002). Security (ADR-004) and async execution (ADR-005) are opt-in. Bearer auth on direct + monitoring routes; HMAC on /webhook; POST /run returns 202 + run_id by default (sync via ?wait=true)."
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Liveness (ADR-005 §2.5): the process is up. Cheap, dependency-free.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Ready",
        "description": "Readiness (ADR-005 §2.5): safe to receive traffic — the store answers and (if async)\nthe worker pool is alive. K8s gates rollouts/routing on this; `503` keeps a not-ready\nreplica out of the pool.",
        "operationId": "ready_ready_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
