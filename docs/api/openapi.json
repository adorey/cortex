    "/tokens": {
      "post": {
        "summary": "Create Token",
        "description": "Mint a Bearer token for a tenant. The RAW token is returned ONCE (only its hash is\nstored). Requires an admin token — this is how the master token issues all the others.",
        "operationId": "create_token_tokens_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TokenCreatePayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List Tokens",
        "description": "List a tenant's tokens — metadata only, never the hash (nor the raw, which is gone).",
        "operationId": "list_tokens_tokens_get",
        "parameters": [
          {
            "name": "tenant",
            "in": "query",
            "required": true,
            "schema": {
