    "/webhook/{source}": {
      "post": {
        "summary": "Webhook",
        "description": "Inbound provider trigger. HMAC over the **raw body** (read here, before any parsing),\nthen the same gate chain + dispatch as ``/run`` (202 by default — providers want a fast\nack). The payload→run mapping is the host-declared binding for ``source``.",
        "operationId": "webhook_webhook__source__post",
        "parameters": [
          {
            "name": "source",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Source"
            }
          },
          {
            "name": "wait",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Wait"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
